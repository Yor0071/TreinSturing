<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>

	<appSettings>
		<add key="Plc.Ip" value="192.168.0.1" />
		<add key="Plc.Rack" value="0" />
		<add key="Plc.Slot" value="2" />
		<add key="Plc.Start" value="2" />
		<add key="Plc.Length" value="16" />
		<add key="Plc.PollIntervalMs" value="200" />
		<add key="Plc.DbScanStart" value="1" />
		<add key="Plc.DbScanEnd" value="81" />

		<add key="Controller.Type" value="Cs2" />
		<add key="Controller.Cs2.Host" value="192.168.0.50" />
		<add key="Controller.Cs2.Port" value="15731" />
		<add key="Controller.Cs2.ConnectTimeoutMs" value="3000" />
		<add key="Controller.SimulationEnabled" value="true" />
	</appSettings>
</configuration>